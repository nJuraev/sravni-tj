# Шаблон переменных окружения для docker-compose. Скопируйте в .env и подставьте значения.
# .env НЕ коммитится и НЕ читается агентом (см. запреты в CLAUDE.md).

# PostgreSQL
DB_DATABASE=sravni
DB_USERNAME=sravni
DB_PASSWORD=change_me

# Laravel (backend/.env берёт эти же значения для подключения к контейнеру db)
# DB_CONNECTION=pgsql
# DB_HOST=db
# DB_PORT=5432

# --- Парсер (Go) ---
# DATABASE_URL по умолчанию собирается из DB_* и хоста db (см. docker-compose).
# Раскомментируйте, только если нужен нестандартный DSN.
# DATABASE_URL=postgres://sravni:change_me@db:5432/sravni?sslmode=disable

# Скрейпер выбирается ПЕР-ИСТОЧНИК (bank_source_urls.scraper / bank_parse_
# instructions.scraper), не этой переменной. По умолчанию — свой скрейпер
# (прямой HTTP GET, бесплатно). Для JS-рендера/anti-bot источников —
# scraper='browser' (свой headless Chrome, см. BROWSER_CDP_URL в docker-compose,
# ключ не нужен) либо 'firecrawl' (платный фолбэк, нужен SCRAPER_API_KEY).
SCRAPER_API_KEY=
# BROWSER_CDP_URL по умолчанию собирается в docker-compose (http://chrome:9222).
# Раскомментируйте, только если Chrome доступен по другому адресу.
# BROWSER_CDP_URL=http://chrome:9222

# AI для извлечения структуры: gemini | qwen | openrouter
AI_PROVIDER=openrouter
# Ключ OpenRouter (https://openrouter.ai/keys), формат sk-or-v1-...
AI_API_KEY=
# Модель OpenRouter. Бесплатный tier — суффикс :free обязателен
# (https://openrouter.ai/collections/free-models). Лимиты на free: ~50 запросов/день,
# 20 RPM. Примеры бесплатных, пригодных для structured output (JSON):
#   deepseek/deepseek-chat-v3.1:free        — дефолт, наиболее стабильна
#   google/gemini-2.0-flash-exp:free        — нативные structured outputs
#   qwen/qwen-2.5-72b-instruct:free
#   meta-llama/llama-3.3-70b-instruct:free
AI_MODEL=deepseek/deepseek-chat-v3.1:free

# Прочее (опционально)
# PARSER_DEBUG_LOG=false
# PARSER_CONCURRENCY=1
