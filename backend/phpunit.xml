<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <!--
          Миграции используют Postgres-специфику (jsonb, GIN, CHECK с regex ~*,
          '{}'::jsonb), поэтому feature-тесты с RefreshDatabase ДОЛЖНЫ идти на
          PostgreSQL (в Docker), а не sqlite :memory:. Значения берутся из
          окружения тестового контейнера (DB_HOST=db и т.д.).
        -->
        <env name="DB_CONNECTION" value="pgsql"/>
        <!--
          Тесты ВСЕГДА идут в отдельную БД sravni_test (force=true перебивает
          DB_DATABASE из окружения/.env), чтобы RefreshDatabase НИКОГДА не
          стирал dev-данные в основной базе sravni. БД создаётся один раз:
          docker compose exec db psql -U sravni -d sravni -c "CREATE DATABASE sravni_test OWNER sravni;"
        -->
        <env name="DB_DATABASE" value="sravni_test" force="true"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
