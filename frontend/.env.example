# Sravni.tj frontend — environment variables.
# Copy to .env.local for local overrides. All vars are optional.

# Base URL of the Laravel REST API. Used only when mocks are OFF.
# Default: http://localhost:8000/api
VITE_API_BASE_URL=http://localhost:8000/api

# Use in-memory mock backend instead of real HTTP calls.
# - `vite dev`   defaults to "true"  (app runs WITHOUT a backend)
# - `vite build` defaults to "false" (production talks to VITE_API_BASE_URL)
# Set explicitly to override the default in either mode.
# VITE_USE_MOCKS=true
